rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'antwifosterfrimpong@gmail.com';
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(authUid()));
    }

    function isAdmin() {
      return isBootstrapAdmin() ||
        (isSignedIn() && currentUserDoc().exists() && currentUserDoc().data.role == 'admin');
    }

    function canMakeEntries() {
      return isAdmin() ||
        (isSignedIn() && currentUserDoc().exists() && currentUserDoc().data.canMakeEntries == true);
    }

    match /users/{userId} {
      allow create: if isSignedIn() && (authUid() == userId || isAdmin());
      allow get: if isSignedIn() && (authUid() == userId || isAdmin());
      allow list: if isAdmin();

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          authUid() == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.canMakeEntries == resource.data.canMakeEntries &&
          request.resource.data.approved == resource.data.approved
        )
      );

      allow delete: if isAdmin();
    }

    match /warehousePortal/{documentId} {
      allow read: if isSignedIn();
      allow write: if canMakeEntries();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
